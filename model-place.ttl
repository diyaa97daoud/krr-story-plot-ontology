@prefix : <http://example.org/krr/story/PlaceOntology#> .
@prefix krr: <http://example.org/krr/story/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rcc: <https://purl.org/region/rcc8/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/krr/story/PlaceOntology> .

<http://example.org/krr/story/PlaceOntology> rdf:type owl:Ontology ;
                                              rdfs:comment "Module for places, place hierarchies, and spatial relations."@en ;
                                              rdfs:label "Place module"@en .

#################################################################
#    Object Properties
#################################################################

###  http://example.org/krr/story/adjacentPlace
krr:adjacentPlace rdf:type owl:ObjectProperty ,
                           owl:SymmetricProperty ;
                  rdfs:domain krr:Place ;
                  rdfs:range krr:Place ;
                  rdfs:comment "Two places that share a boundary or direct transition."@en ;
                  rdfs:label "adjacent place"@en .


###  http://example.org/krr/story/containsPlace
krr:containsPlace rdf:type owl:ObjectProperty ;
                  owl:inverseOf krr:partOfPlace ;
                  rdfs:domain krr:Place ;
                  rdfs:range krr:Place ;
                  rdfs:comment "Inverse relation of partOfPlace."@en ;
                  rdfs:label "contains place"@en .


###  http://example.org/krr/story/partOfPlace
krr:partOfPlace rdf:type owl:ObjectProperty ,
                         owl:TransitiveProperty ;
                rdfs:domain krr:Place ;
                rdfs:range krr:Place ;
                rdfs:comment "Relates a place to a larger place containing it."@en ;
                rdfs:label "part of place"@en .


#################################################################
#    Classes
#################################################################

###  http://example.org/krr/story/Fortress
krr:Fortress rdf:type owl:Class ;
             rdfs:subClassOf krr:Settlement ;
             rdfs:comment "A fortified settlement or stronghold."@en ;
             rdfs:label "fortress"@en .


###  http://example.org/krr/story/Place
krr:Place rdf:type owl:Class ;
          rdfs:subClassOf rcc:Region ;
          rdfs:comment "A meaningful location in a story world."@en ;
          rdfs:label "place"@en .


###  http://example.org/krr/story/Settlement
krr:Settlement rdf:type owl:Class ;
               rdfs:subClassOf krr:Place ;
               rdfs:comment "An inhabited place such as a city, village, or stronghold."@en ;
               rdfs:label "settlement"@en .


###  http://example.org/krr/story/WaterArea
krr:WaterArea rdf:type owl:Class ;
              rdfs:subClassOf krr:Place ;
              rdfs:comment "A place dominated by water, such as a river or sea."@en ;
              rdfs:label "water area"@en .


###  http://example.org/krr/story/WildArea
krr:WildArea rdf:type owl:Class ;
             rdfs:subClassOf krr:Place ;
             rdfs:comment "A non-urban natural area."@en ;
             rdfs:label "wild area"@en .


###  https://purl.org/region/rcc8/Region
rcc:Region rdf:type owl:Class .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( krr:Settlement
                krr:WaterArea
                krr:WildArea
              )
] .


